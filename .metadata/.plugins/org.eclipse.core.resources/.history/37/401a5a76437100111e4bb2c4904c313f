void SD_Log_Stop(void)
{
    if (!sdCardReady)
        return;

    // Flush semua data yang tertinggal di buffer
    for (int i = 0; i < 2; i++)
    {
        if (logBuffer.writeIndex[i] > 0)
        {
            UINT bw;
            SCB_CleanDCache_by_Addr((uint32_t*)logBuffer.buffer[i], logBuffer.writeIndex[i]);

            FRESULT fres = f_write(&logFile, logBuffer.buffer[i], logBuffer.writeIndex[i], &bw);

            // FIX BUG 2: Pastikan data benar-benar ditulis ke SD card
            if (fres == FR_OK && bw == logBuffer.writeIndex[i])
            {
                f_sync(&logFile);  // Sinkronkan setiap buffer
            }
        }
    }

    f_close(&logFile);
    f_mount(NULL, "", 0);

    sdCardReady = 0;
    logBuffer.isLogging = 0;
    logBuffer.isFlushing = 0;
    logBuffer.writeIndex[0] = 0;
    logBuffer.writeIndex[1] = 0;
}

uint8_t bitWrite(uint8_t data, uint8_t kolom, uint8_t value){
    data &= ~(1 << kolom);
    data |= (value << kolom);
    return data;
}

uint8_t bitRead(uint8_t data, uint8_t kolom){
    return (data >> kolom) & 1;
}

long map(long x, long in_min, long in_max, long out_min, long out_max){
    long input_range = in_max - in_min;
    long output_range = out_max - out_min;

    // Pembagian integer terlebih dahulu untuk menghindari overflow
    long scaled = ((x - in_min) * output_range) / input_range;
    return scaled + out_min;
}

