void CANALL_Send(uint32_t id, uint8_t *data, uint8_t len)
{
    if(len < 1 || len > 8) return;

    canAll.Identifier = id;
    canAll.IdType = FDCAN_STANDARD_ID;
    canAll.TxFrameType = FDCAN_DATA_FRAME;
    canAll.DataLength = DLC_Table[len];
    canAll.ErrorStateIndicator = FDCAN_ESI_ACTIVE;
    canAll.BitRateSwitch = FDCAN_BRS_OFF;
    canAll.FDFormat = FDCAN_CLASSIC_CAN;
    canAll.TxEventFifoControl = FDCAN_NO_TX_EVENTS;
    canAll.MessageMarker = 0;

    if(HAL_FDCAN_GetTxFifoFreeLevel(&hfdcan1) > 0)
    {
        HAL_FDCAN_AddMessageToTxFifoQ(&hfdcan1, &canAll, data);
    }
}
void CANMC_Send(uint32_t id, volatile uint8_t *data,  uint8_t len)
{
    canMC.Identifier = id;
    canMC.IdType = FDCAN_STANDARD_ID;
    canMC.TxFrameType = FDCAN_DATA_FRAME;
    canMC.DataLength = DLC_Table[len];
    canMC.ErrorStateIndicator = FDCAN_ESI_ACTIVE;
    canMC.BitRateSwitch = FDCAN_BRS_OFF;
