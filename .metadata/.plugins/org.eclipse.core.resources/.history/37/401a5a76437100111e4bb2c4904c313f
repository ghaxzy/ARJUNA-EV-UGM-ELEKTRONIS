uint16_t mapThrottle(uint16_t adc, uint16_t min, uint16_t max)
{
    if (adc <= min)
        return 0;

    if (adc >= max)
        return 32767;

    return (uint16_t)(((uint32_t)(adc - min) * 32767U) / (max - min));
}

int constrain(int x, int min, int max)
{
    if(x < min) return min;
    if(x > max) return max;
    return x;
}

uint8_t SD_Log_Init(void)
{
    FRESULT fres;
    uint8_t retry_count = 0;
    const uint8_t MAX_RETRIES = 3;

    // FIX BUG 3: Wait for SD card to be ready
    while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER && retry_count < MAX_RETRIES)
    {
        HAL_Delay(50);
        retry_count++;
    }

    if (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER)
    {
        // SD card tidak siap
        return 0;
    }

    SCB_CleanInvalidateDCache();

    fres = f_mount(&fs, "", 1);
    if (fres != FR_OK)
    {
        return 0;
    }

    snprintf(logFileName, sizeof(logFileName),
             "TEMPEK69_%02d_%02d.csv",
             currentTime.Hours, currentTime.Minutes);

    fres = f_open(&logFile, logFileName, FA_CREATE_ALWAYS | FA_WRITE);
    if (fres != FR_OK)
    {
        f_mount(NULL, "", 0);
        return 0;
    }

    const char* header = "Timestamp, Throttle, BSE,BSE,SusTravR,SusTravL,SteeringR,SteeringL,"
                        "ID4_B0,ID4_B1,ID4_B2,ID4_B3,ID4_B4,ID4_B5,ID4_B6,ID4_B7\r\n";

    UINT bw;
    fres = f_write(&logFile, header, strlen(header), &bw);
    if (fres != FR_OK || bw != strlen(header))
    {
        f_close(&logFile);
        f_mount(NULL, "", 0);
        return 0;
    }

    f_sync(&logFile);  // Sync setelah write header
    logBuffer.writeIndex[0] = 0;
    logBuffer.writeIndex[1] = 0;
    logBuffer.activeBuffer = 0;
    logBuffer.lastFlushTick = HAL_GetTick();
    logBuffer.isLogging = 1;
    logBuffer.isFlushing = 0;
    sdCardReady = 1;

    return 1;
}

void SD_Log_AddData(void)
{
    // FIX: Hapus spasi aneh pada logBuffer. isLogging
    if (!sdCardReady || !logBuffer.isLogging || logBuffer.isFlushing)
        return;

    uint8_t bufIdx = logBuffer.activeBuffer;
    uint8_t* activeBuffer = logBuffer.buffer[bufIdx];
    uint32_t idx = logBuffer.writeIndex[bufIdx];

    // FIX BUG 4: Jangan switch buffer saat flush belum selesai
    if (idx + 150 >= LOG_BUFFER_SIZE)
    {
        // Tunggu flush selesai sebelum swap
        if (!logBuffer.isFlushing)
        {
            logBuffer.activeBuffer ^= 1;
            logBuffer.isFlushing = 1;
        }
        return;  // Jangan tambah data, tunggu buffer dikosongkan
    }

    uint32_t ms = HAL_GetTick() % 1000;

    int len = sprintf((char*)&activeBuffer[idx],
                     "%02d:%02d:%02d.%03lu,%u,%u,%u,%u,%u,%u,%u,%u,%u,%u,%u,%u,%u,%u,%u\r\n",
                     currentTime.Hours, currentTime.Minutes, currentTime.Seconds, ms,
                     appsNextion, bsemap, RpmBamo, IActual, Imaxpk, statusBamo, stel,
                     id4_data[0], id4_data[1], id4_data[2], id4_data[3],
                     id4_data[4], id4_data[5], id4_data[6], id4_data[7]);

    logBuffer.writeIndex[bufIdx] = idx + len;
}

void SD_Log_Flush(void)
{
    if (!logBuffer.isFlushing || !sdCardReady)
        return;
    uint8_t bufferToFlush = logBuffer.activeBuffer ^ 1;
    uint8_t* flushBuffer = logBuffer.buffer[bufferToFlush];
    uint32_t flushSize = logBuffer.writeIndex[bufferToFlush];
    if (flushSize == 0)
    {
        logBuffer.isFlushing = 0;
        return;
    }

    UINT bw;
    FRESULT fres;

    SCB_CleanDCache_by_Addr((uint32_t*)flushBuffer, flushSize);
    fres = f_write(&logFile, flushBuffer, flushSize, &bw);

    if (fres == FR_OK && bw == flushSize)
    {
        f_sync(&logFile);
        logBuffer.writeIndex[bufferToFlush] = 0;
    }
    logBuffer.isFlushing = 0;
    logBuffer.lastFlushTick = HAL_GetTick();
}

void SD_Log_CheckFlush(void)
{
    if (!sdCardReady || !logBuffer.isLogging)
        return;

    uint32_t currentTick = HAL_GetTick();
    uint8_t activeIdx = logBuffer.activeBuffer;

    if (logBuffer.isFlushing)
    {
        SD_Log_Flush();
    }

    else if (currentTick - logBuffer.lastFlushTick >= LOG_FLUSH_INTERVAL &&
             logBuffer.writeIndex[activeIdx] > 0)
    {
        logBuffer.activeBuffer ^= 1;
        logBuffer.isFlushing = 1;
        SD_Log_Flush();
    }
}

uint8_t SD_Log_GetSwitchState(void)
