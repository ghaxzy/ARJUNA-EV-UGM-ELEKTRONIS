void loopUtama(void){
	ignBut = HAL_GPIO_ReadPin(IGNPORT, IGNPIN);
	bsemap = map(bse, bsemin, bsemax, 0, 100);
	bsemap = constrain(bsemap, 0, 100);
	appsNextion = map(apps2, 21000, 45000, 0, 100);
	appsNextion = constrain(appsNextion, 0, 100);
	trotleCan = mapThrottle(apps2, 21000, 45000);

	torqueCmd = (70000 * 9.549 * 32767) / (RpmBamo * 0.75 * Imaxpk);
	if(bsemap > 35 && ignBut == 0){
		runSignal = 1;
	}else if(bsemap < 35 && ignBut == 0){
		runSignal = 0;
	}
	if(runSignal){
		HAL_GPIO_WritePin(GPIOC, GPIO_PIN_1, SET);
	}
	if(!runSignal){
		HAL_GPIO_WritePin(GPIOC, GPIO_PIN_1, RESET);
	}
	if(bsemap >= 20)remSignal = 1;
	else if(bsemap < 20)remSignal = 0;

	statusBit = bitWrite(statusBit, 0, runSignal);
	statusBit = bitWrite(statusBit, 1, remSignal);
	canRSM[0] = statusBit;
	if(HAL_GetTick() - waktuid0 >= 10){
		CANALL_Send(0, canRSM, 8);
		waktuid0 = HAL_GetTick();
	}
	canVci[0] = appsNextion;
	canVci[1] = bsemap;
	canVci[2] = statusBit;
	canVci[3] = canStatusRSM[2];
	canVci[4] = canNmc[1];
	canVci[5] = canNmc[2];
	canTorque[0] = 0x90;
	canTorque[1] = trotleCan;//LSB APPS
	canTorque[2] = (trotleCan >> 8) & 0xff;//MSB APPS
	if(HAL_GetTick() - vciInterval >= 60){
		CANALL_Send(6, canVci, 6);
		vciInterval = HAL_GetTick();
	}
	if (HAL_GetTick() - lastTorque >= 10) {
	    CANMC_Send(0x201, canTorque, 3);
	    lastTorque = HAL_GetTick();
	}
//	CANMC_Send(0x201, canTorque, 3);

}

void requestBMS()
{
    static uint32_t lastReq = 0;

    if(HAL_GetTick() - lastReq < 100)
        return;

    lastReq = HAL_GetTick();

    canBMS1[0] = 0x06;
    canBMS1[1] = 1;

    canBMS2[0] = 0x07;
    canBMS2[1] = 1;

    canBMS3[0] = 0x08;
    canBMS3[1] = 1;

    canBMS4[0] = 0x09;
    canBMS4[1] = 1;

    canBMS5[0] = 0x10;
    canBMS5[1] = 1;

    canBMS6[0] = 0x11;
    canBMS6[1] = 1;

    if(varSwitch < 5)
        varSwitch++;
    else
        varSwitch = 0;

    switch(varSwitch)
    {
        case 0: CANALL_Send(0x03, canBMS1, 2); break;
        case 1: CANALL_Send(0x03, canBMS2, 2); break;
        case 2: CANALL_Send(0x03, canBMS3, 2); break;
        case 3: CANALL_Send(0x03, canBMS4, 2); break;
        case 4: CANALL_Send(0x03, canBMS5, 2); break;
        case 5: CANALL_Send(0x03, canBMS6, 2); break;
    }
}

void requestRSM(){
	canRsm1[0] = 0;
	canRsm1[1] = 1;

	canRsm2[0] = 1;
	canRsm2[1] = 1;

	CANALL_Send(1, canRsm1, 2);
	CANALL_Send(1, canRsm2, 2);
}

